// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgres://postgres:1234@localhost:5432/my_app"
}

model Product {
  id          String    @id @default(uuid()) @db.Uuid
  name       String
  slug        String   @unique
  description String
  price       Int      @default(0)
  stock       Int      @default(0)
  // Relation fields
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  
  // PostgreSQL scalar list for images
  images      String[]

  creationAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
}

model Category {
  id         Int       @id @default(autoincrement())
  name       String
  slug       String    @unique
  image      String
  
  // Reverse relation (a category has many products)
  products   Product[]

  creationAt DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model User {
id        String    @id @default(uuid()) @db.Uuid
username  String    @unique
password  String
profile   Profile?

createdAt DateTime  @default(now())
updatedAt DateTime  @updatedAt @default(now())
}

model Profile {
id        String   @id @default(uuid()) @db.Uuid
firstName String
lastName  String
email     String   @unique
phone     String?
address   String?
image     Bytes?

userId    String   @unique @db.Uuid
user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

createdAt DateTime @default(now())
updatedAt DateTime @updatedAt
}
